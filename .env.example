# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE_API_KEY: Optional. Enables Firebase Authentication via REST API.
# Get this from Firebase Console → Project Settings → Web API Key.
# If not set or placeholder, the app falls back to local JSON-based password verification.
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
